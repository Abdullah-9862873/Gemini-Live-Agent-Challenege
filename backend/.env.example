# =============================================
# Making Repos Speakable - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# For local: backend/.env
# For HF Space: Add as Repository Secrets
# For Vercel: Add as Environment Variables
# =============================================

# =============================================
# GROQ API (Free - https://console.groq.com/)
# =============================================
GROQ_API_KEY=your_groq_api_key_here

# =============================================
# PINECONE Vector Database (Free tier available)
# =============================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=making-repos-speakable

# =============================================
# GITHUB (Optional - for private repos)
# =============================================
GITHUB_TOKEN=your_github_token_here

# =============================================
# BACKEND CONFIGURATION (Local only)
# =============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# =============================================
# FRONTEND CONFIGURATION (Vercel only)
# =============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
