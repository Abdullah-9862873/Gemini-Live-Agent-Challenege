# =============================================================================
# AI Multimodal Tutor - Environment Variables Template
# =============================================================================
# Phase: 1 - Project Setup & Infrastructure
# Purpose: Template for environment variables (copy to .env and fill values)
# Version: 1.0.0
# =============================================================================

# =============================================================================
# PINECONE VECTOR DATABASE
# =============================================================================
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=course-vectors

# =============================================================================
# GOOGLE GEMINI LLM
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# =============================================================================
# GITHUB INTEGRATION (Public Repos Only)
# =============================================================================
# Note: No token required for public repositories
# Format: owner/repo-name (e.g., "google/guava" or "yourusername/dsa-course")
GITHUB_REPO=owner/repository-name

# =============================================================================
# GOOGLE CLOUD PLATFORM
# =============================================================================
# Project ID from Google Cloud Console
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Cloud Run deployment
GOOGLE_CLOUD_REGION=us-central1

# =============================================================================
# APPLICATION CONFIG
# =============================================================================
# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# RAG Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
